    "@stripe/react-stripe-js": "4.0.2",
    "recharts": "3.2.0",
    "lucide-react": "^0.469.0",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.3.0",
