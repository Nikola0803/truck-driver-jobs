# Copy to .env and fill in values

# JWT secret — change this in production (long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Anthropic API key — only needed for AI content generation in admin
ANTHROPIC_API_KEY=sk-ant-...

# Admin seed credentials (used by: npm run db:seed)
ADMIN_EMAIL=admin@truckdriverjobs.co
ADMIN_PASSWORD=TDJadmin2026!

# Server port (default 3001)
PORT=3001
